{
  "pageName": "auth-otp-preset",
  "viewport": {
    "width": 375,
    "height": 812
  },
  "routes": [
    {
      "urlPattern": "**/api/v2/auth/email/send-code",
      "status": 200,
      "contentType": "application/json",
      "json": {
        "code": 0,
        "message": "ok",
        "traceId": "mock",
        "data": {
          "requestId": "r1",
          "countdownSec": 59,
          "debugCode": null
        }
      }
    }
  ],
  "steps": [
    {
      "action": "goto",
      "url": "http://127.0.0.1:5173/auth/email?lang=zh-CN"
    },
    {
      "action": "waitForSelector",
      "selector": "#email-input"
    },
    {
      "action": "fill",
      "selector": "#email-input",
      "value": "eotoai@gmail.com"
    },
    {
      "action": "click",
      "selector": "label.agreement-row"
    },
    {
      "action": "click",
      "selector": "button.send-btn"
    },
    {
      "action": "waitMs",
      "ms": 100
    },
    {
      "action": "fill",
      "selector": ".otp-cell:nth-of-type(1)",
      "value": "1"
    },
    {
      "action": "fill",
      "selector": ".otp-cell:nth-of-type(2)",
      "value": "1"
    },
    {
      "action": "fill",
      "selector": ".otp-cell:nth-of-type(3)",
      "value": "1"
    },
    {
      "action": "fill",
      "selector": ".otp-cell:nth-of-type(4)",
      "value": "1"
    },
    {
      "action": "click",
      "selector": ".otp-cell:nth-of-type(5)"
    }
  ]
}
